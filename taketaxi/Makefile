APP_NAME := taketaxi
BFF_NAME := bffDriver
BIN_DIR := bin

# Services
SRV_DIRS := srvDriver
SRV_BINS := srvDriver

.PHONY: all build run run-bff run-srv stop clean proto test

all: build

build: proto
	@mkdir -p $(BIN_DIR)
	@echo 'Building $(APP_NAME)...'
	@cd $(BFF_NAME) && go build -o ../$(BIN_DIR)/$(BFF_NAME) ./cmd/main.go
	@cd srvDriver && go build -o ../$(BIN_DIR)/srvDriver ./cmd/main.go
	@echo 'Build done!'

proto:
	@echo 'Generating proto...'
	@cd scripts && bash gen_proto.sh

run: build
	@echo 'Starting $(APP_NAME)...'
	@$(MAKE) stop 2>/dev/null || true
	@cd srvDriver && nohup ./cmd/main.go > ../log/srvDriver.log 2>&1 &
	@sleep 2
	@cd $(BFF_NAME) && nohup ./cmd/main.go > ../log/$(BFF_NAME).log 2>&1 &
	@echo 'Services started!'
	@echo 'BFF: http://localhost:8080'
	@echo 'Driver SRV: localhost:8001'

run-bff: build
	@$(MAKE) stop-bff 2>/dev/null || true
	@echo 'Starting $(BFF_NAME)...'
	@cd $(BFF_NAME) && nohup ./cmd/main.go > ../log/$(BFF_NAME).log 2>&1 &
	@echo 'BFF started! http://localhost:8080'

run-srv: build
	@$(MAKE) stop-srv 2>/dev/null || true
	@echo 'Starting SRV services...'
	@cd srvDriver && nohup ./cmd/main.go > ../log/srvDriver.log 2>&1 &
	@echo 'SRV services started!'

stop:
	@echo 'Stopping $(APP_NAME)...'
	@-pkill -f '$(BFF_NAME)/cmd/main.go' 2>/dev/null || true
	@-pkill -f 'srvDriver/cmd/main.go' 2>/dev/null || true
	@echo 'All services stopped!'

stop-bff:
	@-pkill -f '$(BFF_NAME)/cmd/main.go' 2>/dev/null || true
	@echo 'BFF stopped!'

stop-srv:
	@-pkill -f 'srvDriver/cmd/main.go' 2>/dev/null || true
	@echo 'SRV services stopped!'

clean:
	@rm -rf $(BIN_DIR)
	@echo 'Clean done!'

test:
	@echo 'Running tests...'
	@cd $(BFF_NAME) && go test ./... -v 2>&1 | head -100
	@cd srvDriver && go test ./... -v 2>&1 | head -50
